{
  "name": "Python",
  "scopeName": "source.python",
  "fileTypes": ["py", "pyw", "pyi"],
  "patterns": [
    { "name": "comment.line.number-sign.python", "match": "#.*$" },
    { "name": "string.quoted.triple.python", "begin": "(?i)[rbfu]{0,2}\"\"\"", "end": "\"\"\"" },
    { "name": "string.quoted.triple.single.python", "begin": "(?i)[rbfu]{0,2}'''", "end": "'''" },
    { "name": "string.quoted.double.python", "match": "(?i)[rbfu]{0,2}\"(?:\\\\.|[^\"\\\\])*\"" },
    { "name": "string.quoted.single.python", "match": "(?i)[rbfu]{0,2}'(?:\\\\.|[^'\\\\])*'" },
    { "name": "constant.numeric.python", "match": "(?i)\\b(0x[0-9a-f_]+|0b[01_]+|0o[0-7_]+|\\d[\\d_]*(\\.[\\d_]+)?(e[-+]?\\d+)?j?)\\b" },
    { "name": "constant.language.python", "match": "\\b(True|False|None|NotImplemented|Ellipsis|__debug__)\\b" },
    { "name": "support.function.decorator.python", "match": "@[A-Za-z_][A-Za-z0-9_.]*" },
    { "name": "keyword.control.python", "match": "\\b(def|class|if|elif|else|for|while|try|except|finally|with|as|import|from|return|yield|lambda|pass|break|continue|global|nonlocal|del|raise|assert|async|await|match|case)\\b" },
    { "name": "keyword.operator.word.python", "match": "\\b(and|or|not|in|is)\\b" },
    { "name": "variable.language.python", "match": "\\b(self|cls)\\b" },
    { "name": "support.function.builtin.python", "match": "\\b(print|len|range|open|input|int|float|str|bytes|list|dict|set|tuple|bool|type|isinstance|issubclass|super|getattr|setattr|hasattr|repr|abs|min|max|sum|sorted|reversed|enumerate|zip|map|filter|any|all|iter|next|id|hash|format|vars|dir|round|divmod|pow|ord|chr|hex|oct|bin|exec|eval)\\b" },
    { "name": "entity.name.function.call.python", "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()" }
  ]
}
