{
  "name": "YAML",
  "scopeName": "source.yaml",
  "fileTypes": ["yml", "yaml"],
  "patterns": [
    { "name": "comment.line.number-sign.yaml", "match": "#.*$" },
    { "name": "keyword.other.document.yaml", "match": "^(---|\\.\\.\\.)\\s*$" },
    { "name": "support.type.key.yaml", "match": "^\\s*(- )*[\"']?[A-Za-z0-9_.-]+[\"']?(?=\\s*:(\\s|$))" },
    { "name": "variable.other.anchor.yaml", "match": "[&*][A-Za-z0-9_-]+" },
    { "name": "keyword.other.tag.yaml", "match": "!!?[A-Za-z0-9_/-]+" },
    { "name": "string.quoted.double.yaml", "match": "\"(?:\\\\.|[^\"\\\\])*\"" },
    { "name": "string.quoted.single.yaml", "match": "'(?:''|[^'])*'" },
    { "name": "constant.language.yaml", "match": "\\b(true|false|null|True|False|Null|TRUE|FALSE|NULL|yes|no|Yes|No|on|off|On|Off)\\b|~" },
    { "name": "constant.numeric.yaml", "match": "(?i)\\b(0x[0-9a-f]+|0o[0-7]+|[-+]?\\d+(\\.\\d+)?(e[-+]?\\d+)?|[-+]?(\\.inf|\\.nan))\\b" },
    { "name": "keyword.operator.block.yaml", "match": "[|>][-+]?\\d*\\s*$" }
  ]
}
