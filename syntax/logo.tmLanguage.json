{
    "name":  "Logo",
    "scopeName":  "source.logo",
    "fileTypes":  [
                      "logo",
                      "glg"
                  ],
    "patterns":  [
                     {
                         "name":  "comment.line.semicolon.logo",
                         "match":  "[;#].*$"
                     },
                     {
                         "name":  "string.quoted.word.logo",
                         "match":  "\"[^\\s\\[\\](){};]*"
                     },
                     {
                         "name":  "variable.other.logo",
                         "match":  ":[A-Za-z_][A-Za-z0-9_.]*"
                     },
                     {
                         "name":  "constant.numeric.logo",
                         "match":  "\\b\\d+(\\.\\d+)?([eE][-+]?\\d+)?\\b"
                     },
                     {
                         "name":  "keyword.control.logo",
                         "match":  "(?i)\\b(TO|POUR|END|FIN|REPEAT|REPETE|IF|SI|IFELSE|SISINON|IFTRUE|SIVRAI|IFT|SIFAUX|IFF|IFFALSE|TEST|TESTE|WHILE|TANTQUE|FOR|REPETEPOUR|FOREACH|POURCHAQUE|STOP|OUTPUT|OP|RETOURNE|RENDS|CATCH|PIEGE|THROW|LANCE|RUN|EXECUTE|LOCAL|MAKE|DONNE|DEFINE|DEFINIS|BYE|QUIT|QUITTE|QUITTER|GOODBYE|HALT|STOPALL|STOPTOUT|TOPLEVEL|RUNRESULT|EXECRESULTAT|AND|OR|NOT|XOR|ET|OU|NON|OUEX)\\b"
                     },
                     {
                         "name":  "support.function.predicate.logo",
                         "match":  "(?i)\\b[a-z][a-z0-9]*\\?"
                     },
                     {
                         "name":  "support.function.dotted.logo",
                         "match":  "(?i)(^|\\s)\\.[a-z]+\\b"
                     },
