{
  "name": "Makefile",
  "scopeName": "source.makefile",
  "fileTypes": ["mk"],
  "patterns": [
    { "name": "comment.line.number-sign.makefile", "match": "#.*$" },
    { "name": "keyword.control.makefile", "match": "\\b(ifeq|ifneq|ifdef|ifndef|else|endif|include|-include|sinclude|define|endef|export|unexport|override|vpath|undefine)\\b" },
    { "name": "keyword.other.special-target.makefile", "match": "^\\.[A-Z_]+(?=\\s*:)" },
    { "name": "variable.other.makefile", "match": "\\$[({][^)}]*[)}]|\\$[@<^+?*%]" },
    { "name": "entity.name.function.target.makefile", "match": "^[A-Za-z0-9_./%-]+(?=\\s*:([^=]|$))" },
    { "name": "string.quoted.double.makefile", "match": "\"[^\"]*\"" },
    { "name": "string.quoted.single.makefile", "match": "'[^']*'" },
    { "name": "constant.numeric.makefile", "match": "\\b\\d+\\b" }
  ]
}
