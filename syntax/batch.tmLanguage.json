{
  "name": "Batch",
  "scopeName": "source.batchfile",
  "fileTypes": ["bat", "cmd"],
  "patterns": [
    { "name": "comment.line.rem.batchfile", "match": "(?i)^\\s*rem\\b.*$" },
    { "name": "comment.line.colon.batchfile", "match": "^\\s*::.*$" },
    { "name": "entity.name.function.label.batchfile", "match": "^\\s*:[A-Za-z_][A-Za-z0-9_-]*" },
    { "name": "string.quoted.double.batchfile", "match": "\"[^\"]*\"" },
    { "name": "variable.other.batchfile", "match": "%(\\*|~?[A-Za-z0-9][A-Za-z0-9_()]*%?|%~?[A-Za-z])" },
    { "name": "variable.other.delayed.batchfile", "match": "![A-Za-z_][A-Za-z0-9_]*!" },
    { "name": "constant.numeric.batchfile", "match": "\\b\\d+\\b" },
    { "name": "keyword.control.batchfile", "match": "(?i)\\b(if|else|for|in|do|goto|call|exit|not|exist|defined|equ|neq|lss|leq|gtr|geq|errorlevel)\\b" },
    { "name": "support.function.builtin.batchfile", "match": "(?i)\\b(echo|set|setlocal|endlocal|shift|pause|choice|start|type|del|erase|copy|xcopy|move|ren|md|mkdir|rd|rmdir|cd|chdir|pushd|popd|cls|title|color|find|findstr|sort|more|attrib|ver|verify|vol|path|prompt)\\b" }
  ]
}
